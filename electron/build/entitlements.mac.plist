<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- MODOROClaw needs these entitlements because Electron's main process spawns
         child processes (openclaw gateway, 9router, openzca listener) and needs to
         load native node modules (better-sqlite3) from outside the app bundle. -->

    <!-- Required for Electron + Node.js native modules under Hardened Runtime -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Required to load .node native modules that may not be signed -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Required to spawn child processes (node, openclaw.mjs, npm) -->
    <key>com.apple.security.cs.disable-executable-page-protection</key>
    <true/>

    <!-- Network access (Telegram API, 9Router HTTP, OpenClaw gateway HTTP) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- File access for workspace files outside the app sandbox -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Allow inheriting these to child processes (openclaw, 9router, openzca subprocesses) -->
    <key>com.apple.security.inherit</key>
    <true/>
</dict>
</plist>
