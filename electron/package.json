{
  "name": "9bizclaw",
  "version": "2.2.55",
  "description": "9BizClaw — Trợ Lý AI Cho CEO (OpenClaw Desktop)",
  "author": "MODORO Tech Corp",
  "repository": {
    "type": "git",
    "url": "https://github.com/modoro-digital/MODOROClaw.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "node scripts/fix-better-sqlite3.js",
    "smoke": "node scripts/smoke-test.js",
    "prebuild:vendor": "node scripts/prebuild-vendor.js",
    "build:win": "node scripts/prebuild-vendor.js && node scripts/smoke-test.js && electron-builder --win",
    "build:mac": "npm run prebuild:vendor && node scripts/smoke-test.js && electron-builder --mac",
    "build:mac:arm": "TARGET_ARCH=arm64 node scripts/prebuild-vendor.js && node scripts/smoke-test.js && electron-builder --mac --arm64",
    "build:mac:intel": "TARGET_ARCH=x64 node scripts/prebuild-vendor.js && node scripts/smoke-test.js && electron-builder --mac --x64",
    "build:mac:universal": "node scripts/smoke-test.js && electron-builder --mac --universal"
  },
  "build": {
    "appId": "vn.9biz.claw",
    "productName": "9BizClaw",
    "copyright": "© 2026 MODORO Tech Corp",
    "publish": null,
    "directories": {
      "output": "../dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "ui/**/*",
      "scripts/**/*",
      "gcal/**/*",
      "patches/**/*",
      "node_modules/**/*",
      "!node_modules/**/{CHANGELOG.md,README.md,readme.md,changelog.md}",
      "!node_modules/**/{test,tests,__tests__,*.test.js,*.spec.js}",
      "!node_modules/**/{example,examples,demo,demos}",
      "!node_modules/**/.bin",
      "!**/*.{md,markdown}",
      "!**/{.DS_Store,Thumbs.db,.git,.svn,.hg}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{.eslintrc,.editorconfig,.prettierrc}"
    ],
    "extraResources": [
      {
        "from": "../AGENTS.md",
        "to": "workspace-templates/AGENTS.md"
      },
      {
        "from": "../BOOTSTRAP.md",
        "to": "workspace-templates/BOOTSTRAP.md"
      },
      {
        "from": "../SOUL.md",
        "to": "workspace-templates/SOUL.md"
      },
      {
        "from": "../IDENTITY.md",
        "to": "workspace-templates/IDENTITY.md"
      },
      {
        "from": "../USER.md",
        "to": "workspace-templates/USER.md"
      },
      {
        "from": "../COMPANY.md",
        "to": "workspace-templates/COMPANY.md"
      },
      {
        "from": "../PRODUCTS.md",
        "to": "workspace-templates/PRODUCTS.md"
      },
      {
        "from": "../MEMORY.md",
        "to": "workspace-templates/MEMORY.md"
      },
      {
        "from": "../HEARTBEAT.md",
        "to": "workspace-templates/HEARTBEAT.md"
      },
      {
        "from": "../TOOLS.md",
        "to": "workspace-templates/TOOLS.md"
      },
      {
        "from": "../README.md",
        "to": "workspace-templates/README.md"
      },
      {
        "from": "../skills",
        "to": "workspace-templates/skills",
        "filter": [
          "**/*",
          "!**/{*.test.js,node_modules}"
        ]
      },
      {
        "from": "../personas",
        "to": "workspace-templates/personas"
      },
      {
        "from": "../industry",
        "to": "workspace-templates/industry"
      },
      {
        "from": "../prompts",
        "to": "workspace-templates/prompts"
      },
      {
        "from": "../memory",
        "to": "workspace-templates/memory",
        "filter": [
          "**/*",
          "!20*.md",
          "!heartbeat-state.json"
        ]
      },
      {
        "from": "../tools",
        "to": "workspace-templates/tools"
      },
      {
        "from": "../docs",
        "to": "workspace-templates/docs"
      },
      {
        "from": "../config",
        "to": "workspace-templates/config",
        "filter": [
          "**/*",
          "!zalo-mode.txt"
        ]
      },
      {
        "from": "../.learnings",
        "to": "workspace-templates/.learnings"
      },
      {
        "from": "../knowledge",
        "to": "workspace-templates/knowledge",
        "filter": [
          "**/*",
          "!**/files/*",
          "!**/index.md"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/better-sqlite3/**",
      "**/pdf-parse/**",
      "**/mammoth/**",
      "scripts/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "vendor-bundle.tar",
          "to": "vendor-bundle.tar"
        },
        {
          "from": "vendor-meta.json",
          "to": "vendor-meta.json"
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "type": "distribution",
      "extraResources": [
        {
          "from": "vendor",
          "to": "vendor",
          "filter": [
            "**/*",
            "!**/{test,tests,__tests__,*.test.js,*.spec.js,*.test.mjs}",
            "!**/{example,examples,demo,demos}",
            "!**/.github/**",
            "!**/{.DS_Store,Thumbs.db,.git,.svn,.hg,.editorconfig,.eslintrc*,.prettierrc*,.npmignore}",
            "!**/{appveyor.yml,.travis.yml,circle.yml}",
            "!**/node/lib/node_modules/npm/node_modules/**",
            "!**/node/lib/node_modules/corepack/**",
            "!**/node/share/**",
            "!**/node/include/**"
          ]
        }
      ],
      "extendInfo": {
        "NSHighResolutionCapable": true,
        "LSMinimumSystemVersion": "11.0.0",
        "NSAppleEventsUsageDescription": "9BizClaw spawns OpenClaw + 9Router subprocesses to power the AI assistant.",
        "NSDesktopFolderUsageDescription": "9BizClaw stores workspace files (knowledge, schedules, logs) under your user data folder."
      },
      "darkModeSupport": true
    },
    "dmg": {
      "title": "9BizClaw ${version}",
      "icon": "build/icon.icns",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 200,
          "type": "file"
        },
        {
          "x": 400,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "compression": "normal",
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "9BizClaw",
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "better-sqlite3": "11.10.0",
    "mammoth": "^1.12.0",
    "node-cron": "^4.2.1",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5"
  }
}
